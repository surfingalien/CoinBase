# Copy this file to .env and fill in real values. NEVER commit .env.

# Coinbase Advanced Trade API (https://www.coinbase.com/settings/api)
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Set to "true" only when you intend to place real orders on Coinbase.
# Defaults to "false" so the system runs against the built-in paper-trading
# exchange simulator until you explicitly opt in.
LIVE_TRADING_ENABLED=false

# Shared secret that TradingView must include in every webhook payload.
WEBHOOK_SECRET=change_me_to_a_long_random_string

DATABASE_URL=sqlite+aiosqlite:///./trading.db

# Risk controls
MAX_POSITION_PCT_OF_PORTFOLIO=0.10
MAX_DAILY_LOSS_PCT=0.05
BASE_TRADE_SIZE_USD=1000
# Long-only, one position per symbol, at most this many symbols held at once.
MAX_OPEN_POSITIONS=5
# Optional hard ceiling on how much of the account's real USD balance the
# system will ever trade with, e.g. 250 to stay within a $250 budget even if
# the connected Coinbase account holds more. All sizing and the daily-loss
# ceiling are computed against min(actual_balance, TRADING_BUDGET_USD).
# Leave at 0 to trade with the full real account balance.
TRADING_BUDGET_USD=0

# Automatic exit management (profit booking / stop-loss / trailing stop)
# The position monitor closes a position the instant an exit condition fires.
# The trailing stop arms once a position is up TRAILING_STOP_ACTIVATION_PCT,
# then sells if price falls TRAILING_STOP_PCT below its peak — letting
# winners run while locking in most of the gain. Set TRAILING_STOP_PCT=0 to
# disable trailing.
TAKE_PROFIT_PCT=0.08
STOP_LOSS_PCT=0.04
TRAILING_STOP_PCT=0.03
TRAILING_STOP_ACTIVATION_PCT=0.04
POSITION_MONITOR_INTERVAL_SECONDS=30

# Market sentiment & news (free, keyless: alternative.me Fear & Greed index
# + CoinDesk/Cointelegraph RSS headlines). Injected into the AI analysis
# prompt and used to damp entry sizes in extreme fear/greed regimes.
SENTIMENT_ENABLED=true
SENTIMENT_CACHE_MINUTES=30

# Minimum minutes between two native-analysis signals for the same symbol.
SIGNAL_COOLDOWN_MINUTES=60

# Native technical + AI analysis (no external app, no token required).
# Computes RSI/MACD/EMA/BB/ATR/ADX/support-resistance/patterns directly from
# Coinbase's own public candle data and polls every pair on a fixed interval
# as an additional signal source alongside the TradingView Pine Script
# webhooks. Runs out of the box with pure rule-based confluence scoring.
#
# Optional: set ANTHROPIC_API_KEY to have Claude turn the indicators into
# the BUY/SELL/HOLD call and reasoning instead of the rule-based fallback.
# Leave blank and everything still works — just without the LLM narrative.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
MARKET_ANALYSIS_POLL_INTERVAL_SECONDS=900
MARKET_ANALYSIS_MIN_CONFIDENCE=0.60
MARKET_ANALYSIS_GRANULARITY_SECONDS=3600

# When true (default), the batched Claude call gets Anthropic's server-side
# web_search tool so it can check for very recent (last 24h) market-moving
# news before deciding — billed per-search, separate from token costs. Only
# takes effect when ANTHROPIC_API_KEY is set. Set to false to disable.
ENABLE_WEB_RESEARCH=true
