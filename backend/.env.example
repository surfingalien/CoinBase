# Copy this file to .env and fill in real values. NEVER commit .env.

# Coinbase Advanced Trade API (https://www.coinbase.com/settings/api)
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Set to "true" only when you intend to place real orders on Coinbase.
# Defaults to "false" so the system runs against the built-in paper-trading
# exchange simulator until you explicitly opt in.
LIVE_TRADING_ENABLED=false

# Optional: OpenAI key to let the AI engine use an LLM for signal reasoning.
# If left blank, the system uses its built-in rule-based decision engine.
OPENAI_API_KEY=

# Shared secret that TradingView must include in every webhook payload.
WEBHOOK_SECRET=change_me_to_a_long_random_string

DATABASE_URL=sqlite+aiosqlite:///./trading.db

# Risk controls
MAX_POSITION_PCT_OF_PORTFOLIO=0.10
MAX_DAILY_LOSS_PCT=0.05
BASE_TRADE_SIZE_USD=1000

# Automatic exit management (profit booking / stop-loss)
# The position monitor closes a position the instant its unrealized P&L
# crosses either threshold, so wins get locked in and losses get cut
# without anyone watching a screen.
TAKE_PROFIT_PCT=0.08
STOP_LOSS_PCT=0.04
POSITION_MONITOR_INTERVAL_SECONDS=30

# FinSurfing integration (https://github.com/surfingalien/finsurfing) — an
# external app with live TradingView charts and a Claude-based technical
# analysis engine. When both values below are set, GainzAI polls it as an
# additional signal source alongside the TradingView Pine Script webhooks.
# Leave blank to disable — the rest of the system works fine without it.
#
# FINSURFING_BASE_URL is FinSurfing's public URL (different host from this
# backend). FINSURFING_API_TOKEN is a JWT signed with FinSurfing's own
# JWT_SECRET — log in to FinSurfing and copy your access token, or mint a
# long-lived service token server-side with that same secret.
FINSURFING_BASE_URL=
FINSURFING_API_TOKEN=
FINSURFING_POLL_INTERVAL_SECONDS=900
FINSURFING_MIN_CONFIDENCE=0.60
FINSURFING_INTERVAL=60
