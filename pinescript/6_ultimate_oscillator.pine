//@version=5
// Ultimate Oscillator Strategy — Multi-Timeframe Reversal
// Larry Williams' Ultimate Oscillator (periods 7/14/28). Enter long when UO
// crosses up through 30 out of oversold; exit when UO reaches 70 or after 5
// candles. Fires webhook alerts to the GainzAI backend on bar close.
strategy("Ultimate Oscillator Strategy", overlay=false, default_qty_type=strategy.percent_of_equity, default_qty_value=3)

len1       = input.int(7, "UO Fast")
len2       = input.int(14, "UO Mid")
len3       = input.int(28, "UO Slow")
osLevel    = input.float(30, "Oversold Cross Level")
obLevel    = input.float(70, "Overbought Exit Level")
maxBars    = input.int(5, "Max Candles In Trade")
webhookSec = input.string("change_me_to_a_long_random_string", "Webhook Secret", group="Webhook")

// Ultimate Oscillator (computed manually — no ta.uo built-in in v5).
bp = close - math.min(low, close[1])
tr = math.max(high, close[1]) - math.min(low, close[1])
avg1 = math.sum(bp, len1) / math.sum(tr, len1)
avg2 = math.sum(bp, len2) / math.sum(tr, len2)
avg3 = math.sum(bp, len3) / math.sum(tr, len3)
uo = 100 * (4 * avg1 + 2 * avg2 + avg3) / 7

var int barsInTrade = 0
inTrade = strategy.position_size > 0
barsInTrade := inTrade ? barsInTrade + 1 : 0

buyCond  = ta.crossover(uo, osLevel) and not inTrade
sellCond = inTrade and (uo >= obLevel or barsInTrade >= maxBars)

payload(action) =>
    '{"webhook_secret":"' + webhookSec + '","strategy":"Ultimate_Oscillator","symbol":"' + syminfo.ticker +
     '-USD","action":"' + action + '","price":' + str.tostring(close) + ',"uo":' + str.tostring(uo) +
     ',"uo_prev":' + str.tostring(uo[1]) + '}'

if buyCond
    strategy.entry("UO Long", strategy.long)
    alert(payload("BUY"), alert.freq_once_per_bar_close)
if sellCond
    strategy.close("UO Long")
    alert(payload("SELL"), alert.freq_once_per_bar_close)

hline(osLevel, "Oversold", color=color.green, linestyle=hline.style_dashed)
hline(obLevel, "Overbought", color=color.red, linestyle=hline.style_dashed)
plot(uo, color=color.new(color.blue, 0), title="Ultimate Oscillator")
plotshape(buyCond, title="Buy", location=location.bottom, color=color.green, style=shape.triangleup, size=size.small)
plotshape(sellCond, title="Sell", location=location.top, color=color.red, style=shape.triangledown, size=size.small)
