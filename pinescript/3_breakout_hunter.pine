//@version=5
// Breakout Hunter — Volatility Expansion
// Donchian channel breakout confirmed by volume surge.
strategy("Breakout Hunter", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=4)

donchLen   = input.int(20, "Donchian Length")
volLen     = input.int(20, "Volume SMA Length")
volMult    = input.float(1.5, "Volume Surge Multiplier")
webhookSec = input.string("change_me_to_a_long_random_string", "Webhook Secret", group="Webhook")

upperCh = ta.highest(high, donchLen)
lowerCh = ta.lowest(low, donchLen)
volSma  = ta.sma(volume, volLen)
volRatio = volume / volSma
atrVal = ta.atr(14)

buyCond  = close >= upperCh[1] and volRatio >= volMult
sellCond = close <= lowerCh[1] and volRatio >= volMult

payload(action) =>
    '{"webhook_secret":"' + webhookSec + '","strategy":"Breakout_Hunter","symbol":"' + syminfo.ticker +
     '-USD","action":"' + action + '","price":' + str.tostring(close) + ',"volume_ratio":' + str.tostring(volRatio) +
     ',"atr":' + str.tostring(atrVal) + ',"donchian_upper":' + str.tostring(upperCh) +
     ',"donchian_lower":' + str.tostring(lowerCh) + '}'

if buyCond
    alert(payload("BUY"), alert.freq_once_per_bar_close)
if sellCond
    alert(payload("SELL"), alert.freq_once_per_bar_close)

plot(upperCh, color=color.green, title="Donchian Upper")
plot(lowerCh, color=color.red, title="Donchian Lower")
plotshape(buyCond, title="Buy", location=location.belowbar, color=color.green, style=shape.triangleup, size=size.small)
plotshape(sellCond, title="Sell", location=location.abovebar, color=color.red, style=shape.triangledown, size=size.small)
